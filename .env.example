# Copia este archivo a .env.local y completa los valores

# Gemini API · habilita el chatbot AIChat
# Obtener key en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Plausible Analytics · dominio en producción
# Crea cuenta en https://plausible.io y registra el dominio
PLAUSIBLE_DOMAIN=castilloitsystems.com

# Google Analytics 4 (opcional, solo si necesitas integración Google Ads)
# Formato: G-XXXXXXXXXX
GA_MEASUREMENT_ID=

# n8n webhook · captura de leads
# Crear workflow en n8n con nodo "Webhook" (POST, JSON). Pegar URL completa de producción.
# Si está vacío, los formularios simulan envío exitoso (modo dev).
N8N_WEBHOOK_URL=https://n8n.castilloitsystems.com/webhook-test/441ab900-de6a-4280-8453-c6370b85af72

# Token opcional · se envía como header X-Webhook-Token
# Útil para validar en n8n que el request viene del sitio (evitar spam directo al webhook)
N8N_WEBHOOK_TOKEN=j5ja8C38rZsRbnsCaWj0gkPLh3xXzXYadZLNSUTVsgY
